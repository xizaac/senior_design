# MongoDB Connection String (paste your Atlas URI here)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/poker-table?retryWrites=true&w=majority

# Server port
PORT=3001

# ESP32 API Key (any secret string you choose — must match what you flash on the ESP32)
ESP32_API_KEY=your-secret-esp32-key-here

# Frontend URL for CORS (change to your deployed frontend URL in production)
FRONTEND_URL=http://localhost:5173
