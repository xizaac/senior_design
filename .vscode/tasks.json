{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: clang build active file",
            "command": "/usr/bin/clang",
            "args": [
                "-fcolor-diagnostics",
                "-fansi-escape-codes",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        },
        {
            "type": "shell",
            "label": "Build equity_debug_test (with equity_calculations.c)",
            "command": "/usr/bin/clang",
            "args": [
                "-fcolor-diagnostics",
                "-fansi-escape-codes",
                "-g",
                "-Wall",
                "${workspaceFolder}/poker-table/esp32/test/equity_debug_test.c",
                "${workspaceFolder}/poker-table/esp32/equity_calculations.c",
                "-o",
                "${workspaceFolder}/poker-table/esp32/test/equity_debug_test"
            ],
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "detail": "equity_debug_test.c has its own main() but calls into equity_calculations.c — the generic 'build active file' task only compiles the single open file, so it can't find those symbols at link time. This task compiles and links both."
        }
    ],
    "version": "2.0.0"
}